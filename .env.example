# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side Supabase (if needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Configuration
POSTGRES_URL=postgresql://user:password@db.supabase.co:5432/postgres
POSTGRES_URL_NON_POOLING=postgresql://user:password@db.supabase.co:5432/postgres
POSTGRES_PRISMA_URL=postgresql://user:password@db.supabase.co:6543/postgres
POSTGRES_HOST=db.supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=postgres

# JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_ANON_KEY=your-anon-key-here
