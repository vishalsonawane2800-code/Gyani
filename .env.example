# Backend (Railway) — public, used by frontend
NEXT_PUBLIC_API_BASE_URL=https://gyani-production.up.railway.app

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-only — set as Cloudflare secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Auth
JWT_SECRET=change-me-to-a-long-random-string
CRON_SECRET=must-match-the-value-in-cloudflare-cron-worker
