{
  "buildCommand": "opennextjs-cloudflare build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".open-next",
  "crons": [
    {
      "path": "/api/cron/update-subscriptions",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scrape-gmp",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scrape-subscription",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scrape-gmp-history",
      "schedule": "30 6,16 * * *"
    }
  ]
}
